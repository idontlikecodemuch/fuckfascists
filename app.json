{
  "expo": {
    "name": "F*ck Fascists",
    "slug": "fuckfascists",
    "version": "0.0.1",
    "newArchEnabled": true,
    "icon": "./assets/pixel/brand/icon.png",
    "splash": {
      "icon": "./assets/pixel/brand/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070B12"
    },
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-asset",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "F*ck Fascists uses your camera to scan product barcodes and match brands to corporate donation records.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Bungee-Regular.ttf",
            "./assets/fonts/IBMPlexSans-Regular.ttf",
            "./assets/fonts/IBMPlexSans-SemiBold.ttf",
            "./assets/fonts/IBMPlexSans-Medium.ttf"
          ]
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.fckapp.fck",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "F*ck Fascists uses your location to find nearby businesses and check their political donation records."
      }
    },
    "android": {
      "package": "com.fckapp.fck"
    }
  }
}
