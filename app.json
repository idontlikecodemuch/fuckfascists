{
  "expo": {
    "name": "FCK",
    "slug": "fuckfascists",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "icon": "./assets/pixel/brand/icon.png",
    "splash": {
      "icon": "./assets/pixel/brand/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070B12"
    },
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-asset",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "FCK uses your camera to scan product barcodes and match brands to corporate donation records.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Bungee-Regular.ttf",
            "./assets/fonts/IBMPlexSans-Regular.ttf",
            "./assets/fonts/IBMPlexSans-SemiBold.ttf",
            "./assets/fonts/IBMPlexSans-Medium.ttf"
          ]
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.fckapp.fck",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FCK uses your location to find nearby businesses and check their political donation records.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fckapp.fck",
      "minSdkVersion": 29
    }
  }
}
